# Linux.do Auto-Read Configuration
# ================================
#
# COOKIES: Replace the placeholder values below with your actual _t cookies.
#          Get them from browser DevTools → Application → Cookies → linux.do → _t
#
# How to get cookies:
# 1. Open browser, log into linux.do
# 2. Press F12 → Application tab → Cookies → https://linux.do
# 3. Find "_t" row, copy the Value
# 4. Paste below (one per account, comma separated)
#
# Cookies expire every ~2 weeks. Refresh them when login starts failing.

USERNAMES=goodhaohao,supercool,superwill
PASSWORDS=
COOKIES=PASTE_GOODHAOHAO_T_COOKIE_HERE,PASTE_SUPERCOOL_T_COOKIE_HERE,PASTE_SUPERWILL_T_COOKIE_HERE
WEBSITE=https://linux.do
AUTO_LIKE=true
HIDE_ACCOUNT_INFO=true
RUN_TIME_LIMIT_MINUTES=25
MAX_CONCURRENT_ACCOUNTS=3
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
